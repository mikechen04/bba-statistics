# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional: restrict slash command sync to one guild for instant updates during development.
# Leave blank to sync commands globally (can take up to ~1 hour to propagate).
DEV_GUILD_ID=

# MCC Island API key from https://gateway.noxcrew.com
MCC_API_KEY=

# Contact info included in the API User-Agent header, per MCC Island API guidelines.
CONTACT_INFO=discord:yourname#0000
